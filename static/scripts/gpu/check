#!/usr/bin/env bash
# GPU utilization for the tmux status bar, as a percentage (like MEM).
# Universal best-effort, ASCII, POSIX-sh. Output: "GPU 37%"
#
#   NVIDIA      -> utilization %   (nvidia-smi)
#   macOS       -> utilization %   (ioreg IOAccelerator, no sudo)
#   AMD/others  -> utilization %   (sysfs gpu_busy_percent)
#   Intel       -> utilization %   (idle-residency delta over 0.3s, root-free:
#                                   xe gtidle/idle_residency_ms or i915 rc6)
#   Intel (last resort) -> clock-based % if no residency counter exists
#
# Silent when no GPU metric is available (e.g. headless servers).

clamp_pct() { # stdin number -> integer 0..100
	awk '{ p = $1; if (p < 0) p = 0; if (p > 100) p = 100; printf "%.0f", p }'
}

# NVIDIA — real utilization.
if command -v nvidia-smi >/dev/null 2>&1; then
	u=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -dc '0-9')
	[ -n "$u" ] && { echo "GPU ${u}%"; exit 0; }
fi

# macOS — Metal/IOAccelerator "Device Utilization %".
if [ "$(uname -s)" = "Darwin" ]; then
	u=$(ioreg -r -d 1 -c IOAccelerator 2>/dev/null \
		| awk -F'=' '/"Device Utilization %"/ { gsub(/[^0-9]/, "", $2); print $2; exit }')
	[ -n "$u" ] && echo "GPU ${u}%"
	exit 0
fi

# AMD and any driver exposing gpu_busy_percent — real utilization.
for f in /sys/class/drm/card*/device/gpu_busy_percent; do
	[ -r "$f" ] || continue
	u=$(cat "$f" 2>/dev/null | tr -dc '0-9')
	[ -n "$u" ] && { echo "GPU ${u}%"; exit 0; }
done

# Intel — combined utilization across ALL GTs (gt0 render, gt1 media, ...)
# from idle-residency deltas (root-free, accurate). Falls back to the single
# i915 rc6 counter. Combined % = 100 - (total idle ms) / (gts * window ms).
gts=
for f in /sys/class/drm/card*/device/tile*/gt*/gtidle/idle_residency_ms; do
	[ -r "$f" ] && gts="$gts $f"
done
[ -n "$gts" ] || for f in /sys/class/drm/card*/power/rc6_residency_ms; do
	[ -r "$f" ] && gts="$gts $f"
done
if [ -n "$gts" ]; then
	sum1=0; cnt=0
	for f in $gts; do
		sum1=$(( sum1 + $(cat "$f" 2>/dev/null | tr -dc '0-9') ))
		cnt=$(( cnt + 1 ))
	done
	t1=$(date +%s%N 2>/dev/null)
	sleep 0.3
	sum2=0
	for f in $gts; do
		sum2=$(( sum2 + $(cat "$f" 2>/dev/null | tr -dc '0-9') ))
	done
	t2=$(date +%s%N 2>/dev/null)
	if [ "$t1" -gt 0 ] && [ "$t2" -gt "$t1" ] 2>/dev/null; then
		dwall=$(( (t2 - t1) / 1000000 ))                 # ns -> ms
		span=$(( cnt * dwall ))                           # idle-possible ms
		if [ "$span" -gt 0 ]; then
			pct=$(awk -v di=$((sum2 - sum1)) -v dt="$span" 'BEGIN { print 100 - di * 100 / dt }' | clamp_pct)
			echo "GPU ${pct}%"
			exit 0
		fi
	fi
fi

# Intel last resort — clock-based proxy (act_freq / max_freq).
for d in /sys/class/drm/card*/device/tile0/gt0/freq0; do
	[ -r "$d/act_freq" ] || continue
	act=$(cat "$d/act_freq" 2>/dev/null | tr -dc '0-9')
	max=$(cat "$d/max_freq" 2>/dev/null | tr -dc '0-9')
	[ -n "$max" ] || max=$(cat "$d/rp0_freq" 2>/dev/null | tr -dc '0-9')
	[ -n "$act" ] && [ -n "$max" ] && [ "$max" -gt 0 ] 2>/dev/null \
		&& { echo "GPU $(awk -v a="$act" -v m="$max" 'BEGIN { print a * 100 / m }' | clamp_pct)%"; exit 0; }
done

exit 0
