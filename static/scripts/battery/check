#!/usr/bin/env bash
# Universal battery indicator for the tmux status bar (POSIX-sh compatible;
# invoked as `sh ~/scripts/battery/check`).
#
#   Linux : reads /sys/class/power_supply/BAT0, optional `acpi` for time-left.
#   macOS : parses `pmset -g batt`.
#
# Plain ASCII so it renders on servers/SSH without any special fonts.
# Output: "BAT 82% [12h 00m]"  (charging shows "+": "BAT +82% [1h 30m]").
# Silent on machines without a battery (desktops/servers).

shorten_time_format() {
	t=$1
	h=$(echo "$t" | awk -F: '{ print $1 }')
	m=$(echo "$t" | awk -F: '{ print $2 }')
	s=$(echo "$t" | awk -F: '{ print $3 }')
	if [ -n "$h" ] && [ "$h" != "00" ] && [ "$h" != "0" ]; then
		echo "${h}h ${m}m"
	elif [ -n "$m" ] && [ "$m" != "00" ] && [ "$m" != "0" ]; then
		if [ -n "$s" ]; then echo "${m}m ${s}s"; else echo "${m}m"; fi
	elif [ -n "$s" ]; then
		echo "${s}s"
	else
		echo "${m}m"
	fi
}

percent=
status=
time_left=

case "$(uname -s)" in
	Linux)
		bat=/sys/class/power_supply/BAT0
		[ -d "$bat" ] || exit 0
		percent=$(cat "$bat/capacity")
		status=$(cat "$bat/status") # Charging / Discharging / Full / ...
		# Time estimate from acpi if available, scoped to the real battery
		# ("Battery 0") so a HID-device battery ("Battery 1") is ignored.
		if command -v acpi >/dev/null 2>&1; then
			time_left=$(acpi -b 2>/dev/null | grep -m1 'Battery 0:' \
				| grep -oE '[0-9]+:[0-9]+:[0-9]+|[0-9]+:[0-9]+' | head -1)
		fi
		;;
	Darwin)
		batt=$(pmset -g batt 2>/dev/null)
		[ -n "$batt" ] || exit 0
		percent=$(echo "$batt" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
		[ -n "$percent" ] || exit 0
		case "$(echo "$batt" | tr 'A-Z' 'a-z')" in
			*discharging*) status=Discharging ;;
			*charging*|*"finishing charge"*) status=Charging ;;
			*charged*) status=Full ;;
			*) status=Unknown ;;
		esac
		time_left=$(echo "$batt" | grep -oE '[0-9]+:[0-9]+' | head -1)
		;;
	*)
		exit 0 ;;
esac

[ -n "$percent" ] || exit 0

prefix=
[ "$status" = "Charging" ] && prefix="+"

suffix=
if [ -n "$time_left" ] && [ "$time_left" != "0:00" ] && [ "$status" != "Full" ]; then
	suffix=" [$(shorten_time_format "$time_left")]"
fi

echo "BAT ${prefix}${percent}%${suffix}"

