#!/usr/bin/env bash
# CPU usage% + 1-minute load average for the tmux status bar.
# Universal: Linux + macOS. Plain ASCII (no fonts/emoji), POSIX-sh compatible.
# Output: "CPU 6% [1.01 load]"

get_cpu_percent() {
	if [ "$(uname -s)" = "Darwin" ]; then
		# macOS: "CPU usage: 4.55% user, 9.09% sys, 86.36% idle"
		top -l 1 -n 0 2>/dev/null | awk '/CPU usage/ {
			for (i = 1; i <= NF; i++) if ($i == "idle") { gsub(/%/, "", $(i-1)); printf "%.0f", 100 - $(i-1) }
		}'
	else
		# Linux: 100 - idle from top's "%Cpu(s)" / "Cpu(s)" line.
		top -bn1 2>/dev/null | grep -i 'Cpu(s)' | head -1 \
			| sed -E 's/.*, *([0-9.]+) *%? *id.*/\1/' \
			| awk '{ printf "%.0f", 100 - $1 }'
	fi
}

get_load_average() {
	# 1-minute load. Portable across Linux ("load average: a, b, c")
	# and macOS ("load averages: a b c").
	uptime | sed -E 's/.*load average[s]?:[[:space:]]*//' | awk '{ gsub(/,/, ""); printf "%.2f", $1 }'
}

main() {
	echo "CPU $(get_cpu_percent)% [$(get_load_average) load]"
}

main
